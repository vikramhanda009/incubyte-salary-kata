generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Employee {
  id        Int      @id @default(autoincrement())
  fullName  String
  jobTitle  String
  country   String
  salary    Float    // Changed from Decimal to Float for SQLite compatibility

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([country])
  @@index([jobTitle])
  @@map("employees")
}